# Database
DATABASE_URL="postgresql://user:password@localhost:5432/drum_roulette"

# Telegram Bot Token (used for HMAC validation)
BOT_TOKEN="your_bot_token_here"

# Telegram Bot Username (без @, используется для реферальных ссылок)
BOT_USERNAME="your_bot_username"

# Числовой ID канала для проверки подписки (бот должен быть администратором канала)
# Получить можно добавив @userinfobot в канал или через getUpdates
CHANNEL_CHAT_ID="-1001234567890"

# Server
PORT=3001
NODE_ENV=development

# CORS
FRONTEND_URL="http://localhost:5173"
