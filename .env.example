# ── Backend ──────────────────────────────────────────────────────────────────

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=

# Telegram Bear Gift ID (get from GET https://api.telegram.org/bot{TOKEN}/getAvailableGifts)
TELEGRAM_BEAR_GIFT_ID=

# Prisma / SQLite (local dev) или PostgreSQL (prod)
DATABASE_URL="file:./dev.db"

# Dev mode: пропускает проверку подписи Telegram
DEV_MODE=true

# ── Frontend ─────────────────────────────────────────────────────────────────

# API URL для продакшена (оставить пустым для локального dev через Vite proxy)
VITE_API_URL=
